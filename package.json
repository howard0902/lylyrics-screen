{
  "name": "spotify-lyrics-lcd",
  "version": "0.2.0",
  "productName": "Spotify Lyrics LCD",
  "description": "A desktop lyric screen for Spotify playback on Thermalright LCDs.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:bridge": "python -m PyInstaller --noconfirm --clean --onefile --name lcd_bridge --distpath dist\\bridge --workpath dist\\bridge-work --specpath dist\\bridge-spec --add-data \"%CD%\\assets\\fonts;assets\\fonts\" --collect-all libusb_package --collect-submodules usb lcd_bridge.py",
    "pack": "electron-builder --dir",
    "dist": "npm run build:bridge && electron-builder --win nsis"
  },
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {},
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.spotifylyricslcd.app",
    "productName": "Spotify Lyrics LCD",
    "artifactName": "${name}-${version}-${arch}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "dist/bridge/lcd_bridge.exe",
        "to": "lcd_bridge.exe"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Spotify Lyrics LCD"
    }
  }
}
